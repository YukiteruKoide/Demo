{
  "datasets": [
    {
      "name": "ds_summary",
      "displayName": "Summary",
      "queryLines": [
        "SELECT COUNT(*) as total_transactions, ROUND(SUM(total_amount)) as total_sales, COUNT(DISTINCT store_id) as active_stores, COUNT(DISTINCT store_name) as store_count FROM users.yukiteru_koide.zerobus_pos_transactions"
      ]
    },
    {
      "name": "ds_pos",
      "displayName": "POS Transactions",
      "queryLines": [
        "SELECT transaction_id, store_id, store_name, register_id, event_time, total_amount, payment_method, customer_id FROM users.yukiteru_koide.zerobus_pos_transactions"
      ]
    },
    {
      "name": "ds_items",
      "displayName": "Item Details",
      "queryLines": [
        "SELECT event_time, HOUR(event_time) as hour, store_name, item.product_name, item.category, item.quantity, item.unit_price, item.quantity * item.unit_price as line_total FROM users.yukiteru_koide.zerobus_pos_transactions LATERAL VIEW explode(items) t AS item"
      ]
    }
  ],
  "pages": [
    {
      "name": "page_overview",
      "displayName": "リアルタイム概況",
      "layout": [
        {
          "widget": {
            "name": "title-overview",
            "multilineTextboxSpec": {
              "lines": [
                "## Zerobus POS リアルタイム分析"
              ]
            }
          },
          "position": {
            "x": 0,
            "y": 0,
            "width": 6,
            "height": 1
          }
        },
        {
          "widget": {
            "name": "subtitle-overview",
            "multilineTextboxSpec": {
              "lines": [
                "Zerobus Ingest REST APIで投入されたPOSデータをリアルタイムに可視化"
              ]
            }
          },
          "position": {
            "x": 0,
            "y": 1,
            "width": 6,
            "height": 1
          }
        },
        {
          "widget": {
            "name": "kpi-total-txn",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_summary",
                  "fields": [
                    {
                      "name": "total_transactions",
                      "expression": "`total_transactions`"
                    }
                  ],
                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "total_transactions",
                  "displayName": "件"
                }
              },
              "frame": {
                "showTitle": true,
                "title": "総トランザクション数"
              }
            }
          },
          "position": {
            "x": 0,
            "y": 2,
            "width": 2,
            "height": 3
          }
        },
        {
          "widget": {
            "name": "kpi-total-sales",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_summary",
                  "fields": [
                    {
                      "name": "total_sales",
                      "expression": "`total_sales`"
                    }
                  ],
                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "total_sales",
                  "displayName": "円"
                }
              },
              "frame": {
                "showTitle": true,
                "title": "総売上"
              }
            }
          },
          "position": {
            "x": 2,
            "y": 2,
            "width": 2,
            "height": 3
          }
        },
        {
          "widget": {
            "name": "kpi-active-stores",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_summary",
                  "fields": [
                    {
                      "name": "active_stores",
                      "expression": "`active_stores`"
                    }
                  ],
                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "active_stores",
                  "displayName": "店舗"
                }
              },
              "frame": {
                "showTitle": true,
                "title": "アクティブ店舗数"
              }
            }
          },
          "position": {
            "x": 4,
            "y": 2,
            "width": 2,
            "height": 3
          }
        },
        {
          "widget": {
            "name": "chart-store-sales",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_pos",
                  "fields": [
                    {
                      "name": "store_name",
                      "expression": "`store_name`"
                    },
                    {
                      "name": "sum(total_amount)",
                      "expression": "SUM(`total_amount`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "bar",
              "encodings": {
                "x": {
                  "fieldName": "store_name",
                  "scale": {
                    "type": "categorical",
                    "sort": {
                      "by": "y-reversed"
                    }
                  },
                  "displayName": "店舗"
                },
                "y": {
                  "fieldName": "sum(total_amount)",
                  "scale": {
                    "type": "quantitative"
                  },
                  "displayName": "売上（円）"
                },
                "label": {
                  "show": true
                }
              },
              "frame": {
                "showTitle": true,
                "title": "店舗別売上ランキング"
              }
            }
          },
          "position": {
            "x": 0,
            "y": 5,
            "width": 3,
            "height": 6
          }
        },
        {
          "widget": {
            "name": "chart-timeline",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_pos",
                  "fields": [
                    {
                      "name": "minute",
                      "expression": "DATE_TRUNC(\"MINUTE\", `event_time`)"
                    },
                    {
                      "name": "count(transaction_id)",
                      "expression": "COUNT(`transaction_id`)"
                    },
                    {
                      "name": "sum(total_amount)",
                      "expression": "SUM(`total_amount`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "line",
              "encodings": {
                "x": {
                  "fieldName": "minute",
                  "scale": {
                    "type": "temporal"
                  },
                  "displayName": "時刻"
                },
                "y": {
                  "fieldName": "count(transaction_id)",
                  "scale": {
                    "type": "quantitative"
                  },
                  "displayName": "トランザクション数"
                }
              },
              "frame": {
                "showTitle": true,
                "title": "時間帯別トランザクション推移"
              }
            }
          },
          "position": {
            "x": 3,
            "y": 5,
            "width": 3,
            "height": 6
          }
        },
        {
          "widget": {
            "name": "chart-payment",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_pos",
                  "fields": [
                    {
                      "name": "payment_method",
                      "expression": "`payment_method`"
                    },
                    {
                      "name": "count(transaction_id)",
                      "expression": "COUNT(`transaction_id`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "pie",
              "encodings": {
                "angle": {
                  "fieldName": "count(transaction_id)",
                  "scale": {
                    "type": "quantitative"
                  },
                  "displayName": "件数"
                },
                "color": {
                  "fieldName": "payment_method",
                  "scale": {
                    "type": "categorical"
                  },
                  "displayName": "決済方法"
                }
              },
              "frame": {
                "showTitle": true,
                "title": "決済方法内訳"
              }
            }
          },
          "position": {
            "x": 0,
            "y": 11,
            "width": 3,
            "height": 6
          }
        },
        {
          "widget": {
            "name": "chart-sales-timeline",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_pos",
                  "fields": [
                    {
                      "name": "minute",
                      "expression": "DATE_TRUNC(\"MINUTE\", `event_time`)"
                    },
                    {
                      "name": "sum(total_amount)",
                      "expression": "SUM(`total_amount`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "area",
              "encodings": {
                "x": {
                  "fieldName": "minute",
                  "scale": {
                    "type": "temporal"
                  },
                  "displayName": "時刻"
                },
                "y": {
                  "fieldName": "sum(total_amount)",
                  "scale": {
                    "type": "quantitative"
                  },
                  "displayName": "売上（円）"
                }
              },
              "frame": {
                "showTitle": true,
                "title": "売上推移（累積エリア）"
              }
            }
          },
          "position": {
            "x": 3,
            "y": 11,
            "width": 3,
            "height": 6
          }
        }
      ],
      "pageType": "PAGE_TYPE_CANVAS"
    },
    {
      "name": "page_products",
      "displayName": "商品分析",
      "layout": [
        {
          "widget": {
            "name": "title-products",
            "multilineTextboxSpec": {
              "lines": [
