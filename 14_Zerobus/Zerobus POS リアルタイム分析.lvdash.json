              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_items",
                  "fields": [
                    {
                      "name": "product_name",
                      "expression": "`product_name`"
                    },
                    {
                      "name": "category",
                      "expression": "`category`"
                    },
                    {
                      "name": "sum(quantity)",
                      "expression": "SUM(`quantity`)"
                    },
                    {
                      "name": "sum(line_total)",
